{
  "name": "finance-assistant",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "api",
    "mobile",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace api run dev",
    "dev:mobile": "npm --workspace mobile run start",
    "dev:mobile:web": "npm --workspace mobile run web",
    "typecheck": "npm --workspace api run typecheck && npm --workspace mobile run typecheck",
    "build:api": "npm --workspace api run build"
  }
}
